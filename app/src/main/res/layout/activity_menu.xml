<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel de Control"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D1B4C"
            android:layout_marginBottom="30dp"/>

        <!-- INGRESAR ESTUDIANTES -->
        <LinearLayout
            android:id="@+id/cardIngresar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_menu"
            android:orientation="horizontal"
            android:padding="22dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_add"
                android:tint="#3949AB"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Ingresar Estudiantes"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Registrar nuevos estudiantes"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

        <!-- VER ASISTENCIA -->
        <LinearLayout
            android:id="@+id/cardVerAsistencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_menu"
            android:orientation="horizontal"
            android:padding="22dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#00897B"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Ver Asistencia"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Consultar registros"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

        <!-- CENTRO DE CONTROL -->
        <LinearLayout
            android:id="@+id/cardCentroControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_menu"
            android:orientation="horizontal"
            android:padding="22dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#F57C00"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Centro de Control"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Configuración del sistema"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardComunicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_menu"
            android:orientation="horizontal"
            android:padding="22dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#8E24AA"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Comunicación"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Enviar mensajes"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

        <!-- SERVICIO GPS -->
        <LinearLayout
            android:id="@+id/cardGPS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_menu"
            android:orientation="horizontal"
            android:padding="22dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#D32F2F"
                android:layout_marginEnd="18dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Servicio GPS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Ubicación del dispositivo"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>